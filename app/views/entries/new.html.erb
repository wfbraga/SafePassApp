<%= turbo_frame_tag 'main-dashboard' do %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h1>New Entry</h1>
  <%= link_to 'Back', entries_path, class: 'btn btn-outline-secondary' %>
</div>
<div class="row">
  <div class="col">
    <div class="card">
      <div class="card-body">
        <%= render 'form' %>
      </div>
    </div>
  </div>
</div>
<% end %>